{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "limusic",
  "version": "0.1.0",
  "identifier": "com.limusic.desktop",
  "build": {
    "frontendDist": "../ui/build",
    "devUrl": "http://localhost:5183",
    "beforeDevCommand": "pnpm --dir ../ui dev",
    "beforeBuildCommand": "pnpm --dir ../ui build"
  },
  "app": {
    "windows": [
      {
        "title": "Limusic",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
